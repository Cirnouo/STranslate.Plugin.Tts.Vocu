<UserControl
    x:Class="STranslate.Plugin.Tts.Vocu.View.SiteSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:plugin="clr-namespace:STranslate.Plugin;assembly=STranslate.Plugin"
    xmlns:conv="clr-namespace:STranslate.Plugin.Tts.Vocu.Converter"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:vm="clr-namespace:STranslate.Plugin.Tts.Vocu.ViewModel"
    d:DataContext="{d:DesignInstance Type=vm:SiteSettingsViewModel}"
    d:DesignHeight="900"
    d:DesignWidth="600"
    mc:Ignorable="d">

    <UserControl.Resources>
        <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
    </UserControl.Resources>

    <ikw:SimpleStackPanel Spacing="12">

        <!-- ════════ 账户与接口 ════════ -->

        <TextBlock
            Margin="0,4,0,0"
            FontSize="14"
            FontWeight="SemiBold"
            Text="{DynamicResource STranslate_Plugin_Tts_Vocu_Group_AccountApi}" />

        <!-- 账户信息 -->
        <ui:SettingsCard Header="{DynamicResource STranslate_Plugin_Tts_Vocu_AccountInfo}">
            <ui:SettingsCard.Description>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse
                        Width="32" Height="32"
                        Margin="0,0,8,0"
                        Visibility="{Binding AvatarUrl, Converter={StaticResource StringToVisibilityConverter}}">
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="{Binding AvatarUrl}" Stretch="UniformToFill" />
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock
                        MaxWidth="180"
                        TextTrimming="CharacterEllipsis"
                        VerticalAlignment="Center"
                        Text="{Binding UserName, FallbackValue=''}" />
                    <TextBlock Margin="8,0,0,0" Text="|" VerticalAlignment="Center" Visibility="{Binding UserName, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}" />
                    <TextBlock Margin="8,0,0,0" Text="{DynamicResource STranslate_Plugin_Tts_Vocu_Credits}" VerticalAlignment="Center" Visibility="{Binding UserCredits, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}" />
                    <TextBlock Margin="4,0,0,0" Text="{Binding UserCredits}" VerticalAlignment="Center" Visibility="{Binding UserCredits, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}" />
                </StackPanel>
            </ui:SettingsCard.Description>
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.Person_24_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="{Binding LatencyBrush}"
                    Text="{Binding LatencyText}"
                    Visibility="{Binding LatencyText, Converter={StaticResource StringToVisibilityConverter}}" />
                <Button
                    Command="{Binding RefreshUserInfoCommand}"
                    Content="{DynamicResource STranslate_Plugin_Tts_Vocu_Refresh}" />
            </StackPanel>
        </ui:SettingsCard>

        <!-- API Base URL (只读) -->
        <ui:SettingsCard Header="{DynamicResource STranslate_Plugin_Tts_Vocu_Url}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.Globe_24_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <TextBlock
                VerticalAlignment="Center"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="{Binding SiteApiBaseUrl}" />
        </ui:SettingsCard>

        <!-- API Key -->
        <ui:SettingsCard Header="{DynamicResource STranslate_Plugin_Tts_Vocu_ApiKey}">
            <ui:SettingsCard.Description>
                <ui:HyperlinkButton
                    Content="{Binding SiteName}"
                    NavigateUri="{Binding SiteWebUrl}" />
            </ui:SettingsCard.Description>
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.Key_24_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <PasswordBox
                MinWidth="300"
                plugin:PasswordBoxAssistant.Attach="True"
                plugin:PasswordBoxAssistant.Password="{Binding ApiKey}"
                ui:ControlHelper.PlaceholderText="{DynamicResource STranslate_Plugin_Tts_Vocu_ApiKey_Placeholder}" />
        </ui:SettingsCard>

        <!-- ════════ 语音 ════════ -->

        <TextBlock
            Margin="0,8,0,0"
            FontSize="14"
            FontWeight="SemiBold"
            Text="{DynamicResource STranslate_Plugin_Tts_Vocu_Group_Voice}" />

        <!-- 语音角色 ID -->
        <ui:SettingsCard Header="{DynamicResource STranslate_Plugin_Tts_Vocu_VoiceId}">
            <ui:SettingsCard.Description>
                <ui:HyperlinkButton
                    Content="{Binding SiteName}"
                    NavigateUri="{Binding SiteWebUrl}" />
            </ui:SettingsCard.Description>
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.PersonVoice_24_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <TextBox
                MinWidth="300"
                ui:ControlHelper.PlaceholderText="{DynamicResource STranslate_Plugin_Tts_Vocu_VoiceId_Placeholder}"
                Text="{Binding VoiceId}" />
        </ui:SettingsCard>

        <!-- 角色风格 -->
        <ui:SettingsCard Header="{DynamicResource STranslate_Plugin_Tts_Vocu_PromptId}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.StyleGuide_24_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <TextBox
                MinWidth="200"
                ui:ControlHelper.PlaceholderText="default"
                Text="{Binding PromptId}" />
        </ui:SettingsCard>

        <!-- ════════ 生成参数 ════════ -->

        <TextBlock
            Margin="0,8,0,0"
            FontSize="14"
            FontWeight="SemiBold"
            Text="{DynamicResource STranslate_Plugin_Tts_Vocu_Group_Generation}" />

        <!-- 参数预设 -->
        <ui:SettingsCard Header="{DynamicResource STranslate_Plugin_Tts_Vocu_Preset}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.Options_24_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <ComboBox
                MinWidth="150"
                ItemsSource="{Binding Presets}"
                SelectedItem="{Binding SelectedPreset}" />
        </ui:SettingsCard>

        <!-- 语言 -->
        <ui:SettingsCard Header="{DynamicResource STranslate_Plugin_Tts_Vocu_Language}">
            <ui:SettingsCard.Description>
                <TextBlock Text="{DynamicResource STranslate_Plugin_Tts_Vocu_Language_Description}" />
            </ui:SettingsCard.Description>
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.LocalLanguage_24_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <ComboBox
                MinWidth="120"
                ItemsSource="{Binding Languages}"
                SelectedItem="{Binding SelectedLanguage}" />
        </ui:SettingsCard>

        <!-- 语速 -->
        <ui:SettingsCard Header="{DynamicResource STranslate_Plugin_Tts_Vocu_SpeechRate}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.TopSpeed_24_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <StackPanel Orientation="Horizontal">
                <Slider
                    Width="180"
                    IsSnapToTickEnabled="True"
                    Maximum="2.0"
                    Minimum="0.5"
                    TickFrequency="0.01"
                    Value="{Binding SpeechRate}" />
                <TextBlock
                    MinWidth="36"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Text="{Binding SpeechRate, StringFormat='{}{0:F2}'}" />
            </StackPanel>
        </ui:SettingsCard>

        <!-- ════════ 高级选项 ════════ -->

        <TextBlock
            Margin="0,8,0,0"
            FontSize="14"
            FontWeight="SemiBold"
            Text="{DynamicResource STranslate_Plugin_Tts_Vocu_Group_Advanced}" />

        <!-- 文本情感 -->
        <ui:SettingsCard
            Description="{DynamicResource STranslate_Plugin_Tts_Vocu_BreakClone_Description}"
            Header="{DynamicResource STranslate_Plugin_Tts_Vocu_BreakClone}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.TextEditStyle_24_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <ui:ToggleSwitch IsOn="{Binding BreakClone}" />
        </ui:SettingsCard>

        <!-- 生动表达 -->
        <ui:SettingsCard
            Description="{DynamicResource STranslate_Plugin_Tts_Vocu_Vivid_Description}"
            Header="{DynamicResource STranslate_Plugin_Tts_Vocu_Vivid}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.Sparkle_24_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <ui:ToggleSwitch IsOn="{Binding Vivid}" />
        </ui:SettingsCard>

        <!-- 低延迟 -->
        <ui:SettingsCard
            Description="{DynamicResource STranslate_Plugin_Tts_Vocu_Flash_Description}"
            Header="{DynamicResource STranslate_Plugin_Tts_Vocu_Flash}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.Flash_24_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <ui:ToggleSwitch IsOn="{Binding Flash}" />
        </ui:SettingsCard>

        <!-- ════════ 情绪控制 ════════ -->

        <TextBlock
            Margin="0,8,0,0"
            FontSize="14"
            FontWeight="SemiBold"
            Text="{DynamicResource STranslate_Plugin_Tts_Vocu_Group_Emotion}" />

        <ui:SettingsCard Header="{DynamicResource STranslate_Plugin_Tts_Vocu_EmoAngry}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.EmojiAngry_24_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <StackPanel Orientation="Horizontal">
                <Slider
                    Width="160"
                    IsSnapToTickEnabled="True"
                    Maximum="10"
                    Minimum="0"
                    TickFrequency="1"
                    Value="{Binding EmoAngry}" />
                <TextBlock
                    MinWidth="24"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Text="{Binding EmoAngry}" />
            </StackPanel>
        </ui:SettingsCard>

        <ui:SettingsCard Header="{DynamicResource STranslate_Plugin_Tts_Vocu_EmoHappy}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.EmojiLaugh_24_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <StackPanel Orientation="Horizontal">
                <Slider
                    Width="160"
                    IsSnapToTickEnabled="True"
                    Maximum="10"
                    Minimum="0"
                    TickFrequency="1"
                    Value="{Binding EmoHappy}" />
                <TextBlock
                    MinWidth="24"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Text="{Binding EmoHappy}" />
            </StackPanel>
        </ui:SettingsCard>

        <ui:SettingsCard Header="{DynamicResource STranslate_Plugin_Tts_Vocu_EmoNeutral}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.EmojiMeh_24_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <StackPanel Orientation="Horizontal">
                <Slider
                    Width="160"
                    IsSnapToTickEnabled="True"
                    Maximum="10"
                    Minimum="0"
                    TickFrequency="1"
                    Value="{Binding EmoNeutral}" />
                <TextBlock
                    MinWidth="24"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Text="{Binding EmoNeutral}" />
            </StackPanel>
        </ui:SettingsCard>

        <ui:SettingsCard Header="{DynamicResource STranslate_Plugin_Tts_Vocu_EmoSad}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.EmojiSad_24_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <StackPanel Orientation="Horizontal">
                <Slider
                    Width="160"
                    IsSnapToTickEnabled="True"
                    Maximum="10"
                    Minimum="0"
                    TickFrequency="1"
                    Value="{Binding EmoSad}" />
                <TextBlock
                    MinWidth="24"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Text="{Binding EmoSad}" />
            </StackPanel>
        </ui:SettingsCard>

        <ui:SettingsCard Header="{DynamicResource STranslate_Plugin_Tts_Vocu_EmoContext}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.TextAlignJustify_24_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <StackPanel Orientation="Horizontal">
                <Slider
                    Width="160"
                    IsSnapToTickEnabled="True"
                    Maximum="10"
                    Minimum="0"
                    TickFrequency="1"
                    Value="{Binding EmoContext}" />
                <TextBlock
                    MinWidth="24"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Text="{Binding EmoContext}" />
            </StackPanel>
        </ui:SettingsCard>

        <!-- ════════ 其他 ════════ -->

        <TextBlock
            Margin="0,8,0,0"
            FontSize="14"
            FontWeight="SemiBold"
            Text="{DynamicResource STranslate_Plugin_Tts_Vocu_Group_Misc}" />

        <!-- 种子 -->
        <ui:SettingsCard Header="{DynamicResource STranslate_Plugin_Tts_Vocu_Seed}">
            <ui:SettingsCard.Description>
                <TextBlock Text="{DynamicResource STranslate_Plugin_Tts_Vocu_Seed_Description}" />
            </ui:SettingsCard.Description>
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.NumberSymbol_24_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <TextBox
                MinWidth="120"
                ui:ControlHelper.PlaceholderText="-1"
                Text="{Binding Seed}" />
        </ui:SettingsCard>

        <!-- 支持 -->
        <ui:SettingsCard
            Description="{DynamicResource STranslate_Plugin_Tts_Vocu_Support_Description}"
            Header="{DynamicResource STranslate_Plugin_Tts_Vocu_Support}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.PersonSupport_20_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <ui:HyperlinkButton Content="{Binding SiteName}" NavigateUri="{Binding SiteWebUrl}" />
        </ui:SettingsCard>

    </ikw:SimpleStackPanel>
</UserControl>
