    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Group_Emotion">情緒控制</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Group_Misc">其他</sys:String>

    <!-- ═══ 帳戶 ═══ -->
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_AccountInfo">帳戶資訊</sys:String>
