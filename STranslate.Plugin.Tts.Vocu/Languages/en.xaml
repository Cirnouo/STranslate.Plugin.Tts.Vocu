<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ═══ Group Headers ═══ -->
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Group_AccountApi">Account &amp; API</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Group_Voice">Voice</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Group_Generation">Generation Parameters</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Group_Advanced">Advanced Options</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Group_Emotion">Emotion Control</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Group_Misc">Other</sys:String>

    <!-- ═══ Account ═══ -->
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_AccountInfo">Account Info</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Credits">Credits:</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Refresh">Refresh</sys:String>

    <!-- ═══ API ═══ -->
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Url">API URL</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_ApiKey">API Key</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_ApiKey_Placeholder">Enter your API Key</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_ApiKey_Empty">Please configure your API Key first</sys:String>

    <!-- ═══ Voice ═══ -->
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_VoiceId">Voice ID</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_VoiceId_Placeholder">Enter Voice ID (required)</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_VoiceId_Empty">Please configure a Voice ID first</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_PromptId">Prompt Style</sys:String>

    <!-- ═══ Generation ═══ -->
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Preset">Preset</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Language">Language</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Language_Description">Language of the text to synthesize</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_SpeechRate">Speech Rate</sys:String>

    <!-- ═══ Advanced ═══ -->
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_BreakClone">Text Emotion</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_BreakClone_Description">Prefer text emotion style over voice clone</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Vivid">Vivid Expression</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Vivid_Description">Vivid expression mode (V3.0 voices only)</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Flash">Low Latency</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Flash_Description">Enable low-latency mode for faster response</sys:String>

    <!-- ═══ Emotion ═══ -->
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_EmoAngry">Angry</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_EmoHappy">Happy</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_EmoNeutral">Neutral</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_EmoSad">Sad</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_EmoContext">Context Match</sys:String>

    <!-- ═══ Misc ═══ -->
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Seed">Seed</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Seed_Description">-1 for random</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Support">Support</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Support_Description">Powered by vocu.ai / wusound.cn TTS API</sys:String>

    <!-- ═══ Tab Headers ═══ -->
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Tab_Wusound">Wusound</sys:String>

    <!-- ═══ Runtime Messages ═══ -->
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Text_Empty">Text content cannot be empty</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Audio_Empty">API returned empty audio data</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Parse_Error">Failed to parse API response</sys:String>

</ResourceDictionary>
