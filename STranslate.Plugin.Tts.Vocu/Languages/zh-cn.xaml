<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ═══ 分组标题 ═══ -->
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Group_AccountApi">账户与接口</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Group_Voice">语音</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Group_Generation">生成参数</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Group_Advanced">高级选项</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Group_Emotion">情绪控制</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Group_Misc">其他</sys:String>

    <!-- ═══ 账户 ═══ -->
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_AccountInfo">账户信息</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Credits">剩余点数:</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Refresh">刷新</sys:String>

    <!-- ═══ 接口 ═══ -->
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Url">接口地址</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_ApiKey">API Key</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_ApiKey_Placeholder">请输入 API Key</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_ApiKey_Empty">请先配置 API Key</sys:String>

    <!-- ═══ 语音 ═══ -->
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_VoiceId">语音角色 ID</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_VoiceId_Placeholder">请输入语音角色 ID（必填）</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_VoiceId_Empty">请先配置语音角色 ID</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_PromptId">角色风格</sys:String>

    <!-- ═══ 生成参数 ═══ -->
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Preset">参数预设</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Language">语言</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Language_Description">待合成文本的语言</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_SpeechRate">语速</sys:String>

    <!-- ═══ 高级选项 ═══ -->
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_BreakClone">文本情感</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_BreakClone_Description">优先使用文本情感风格而非音色克隆</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Vivid">生动表达</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Vivid_Description">生动表达模式（仅 V3.0 角色）</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Flash">低延迟</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Flash_Description">启用低延迟模式以加快响应速度</sys:String>

    <!-- ═══ 情绪控制 ═══ -->
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_EmoAngry">愤怒</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_EmoHappy">开心</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_EmoNeutral">平静</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_EmoSad">悲伤</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_EmoContext">跟随文本</sys:String>

    <!-- ═══ 其他 ═══ -->
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Seed">种子</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Seed_Description">-1 为随机</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Support">支持</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Support_Description">基于 vocu.ai / wusound.cn 语音合成 API</sys:String>

    <!-- ═══ Tab 标题 ═══ -->
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Tab_Wusound">悟声</sys:String>

    <!-- ═══ 运行时消息 ═══ -->
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Text_Empty">文本内容不能为空</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Audio_Empty">API 返回的音频数据为空</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Vocu_Parse_Error">解析 API 响应失败</sys:String>

</ResourceDictionary>
